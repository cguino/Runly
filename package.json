{
  "name": "runly",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "expo start --clear",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --clean --platform ios",
    "prebuild:android": "expo prebuild --clean --platform android",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "android:release": "SENTRY_DISABLE_AUTO_UPLOAD=true ./android/gradlew -p android :app:assembleRelease",
    "open-android": "open -a \"Android Studio\" ./android",
    "tcp": "adb reverse tcp:8081 tcp:8081",
    "lint": "expo lint --max-warnings 0",
    "lint:fix": "expo lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "pre-pr": "yarn lint && yarn type-check && yarn check:contrast && yarn test --coverage",
    "clean": "rm -rf node_modules .expo ios android yarn.lock",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "golden:plans": "tsx scripts/generate-golden-plans.ts"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~8.19.0",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/react-query": "^5.90.0",
    "expo": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.0",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.5",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "i18next": "^25.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^15.7.0",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/jest-preset": "0.86.0",
    "@types/jest": "^29",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^57.0.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "resolver": "react-native-worklets/jest/resolver.js",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@sentry/react-native$": "<rootDir>/test/mocks/sentry.ts",
      "^@shopify/react-native-skia$": "<rootDir>/test/mocks/skia.ts",
      "^expo-notifications$": "<rootDir>/test/mocks/expo-notifications.ts",
      "^@react-native-async-storage/async-storage$": "@react-native-async-storage/async-storage/jest/async-storage-mock"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|react-native-worklets|standard-navigation)"
    ]
  }
}
